# Copy to `.env.local` (create-react-app). Do not commit real tokens.

# Legion Phase 1 API (Express + Prisma). When set, sites/buildings/floors/equipment/points load from the backend.
# Example: http://localhost:4000
REACT_APP_API_BASE_URL=

# Optional: must match backend DEMO_CAMPUS_SITE_ID if you override the seeded site id
# REACT_APP_DEMO_CAMPUS_SITE_ID=cafe0000-0000-4000-8000-00000000babe

# Mapbox public access token — uses the default public style mapbox/streets-v12 (full-color Streets) for raster tiles.
# https://account.mapbox.com/access-tokens/
REACT_APP_MAPBOX_TOKEN=
