generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SiteVersionStatus {
  WORKING
  RELEASED
  ARCHIVED
}

model Site {
  id        String       @id @default(uuid())
  name      String
  status    EntityStatus @default(ACTIVE)
  /// Engineering / Site Builder metadata (persisted; working-version sync reads these)
  timezone         String?
  siteType         String?
  description      String?
  displayLabel     String?
  engineeringNotes String?
  icon             String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  /// User who created the site (shown as project owner in UIs that filter by creator)
  createdByUserId String?
  createdByUser   User?   @relation("SitesCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  activeReleaseVersionId String? @unique
  activeReleaseVersion   SiteVersion? @relation("ActiveRelease", fields: [activeReleaseVersionId], references: [id], onDelete: SetNull)

  buildings         Building[]
  equipment         Equipment[]
  points            Point[]
  userSiteAccess    UserSiteAccess[]
  siteVersions      SiteVersion[]
  alarmDefinitions  AlarmDefinition[]
  alarmEvents       AlarmEvent[]
}

model SiteVersion {
  id        String @id @default(uuid())
  siteId    String
  versionNumber Int
  status    SiteVersionStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  deployedAt DateTime?
  parentVersionId String?
  notes     String?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent SiteVersion? @relation("VersionHierarchy", fields: [parentVersionId], references: [id], onDelete: SetNull)
  children SiteVersion[] @relation("VersionHierarchy")
  payload SiteVersionPayload?
  activeReleaseForSite Site? @relation("ActiveRelease")

  @@unique([siteId, versionNumber])
  @@index([siteId])
  @@index([status])
  @@index([siteId, status])
}

model SiteVersionPayload {
  id            String @id @default(uuid())
  siteVersionId String @unique
  payloadJson   Json

  siteVersion SiteVersion @relation(fields: [siteVersionId], references: [id], onDelete: Cascade)
}

model Building {
  id           String       @id @default(uuid())
  siteId       String
  name         String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String
  latitude     Float?
  longitude    Float?
  status       EntityStatus @default(ACTIVE)
  buildingType String?
  buildingCode String?
  /// Operator building page hero / tagline (optional; falls back to site description)
  description  String?
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  floors    Floor[]
  equipment Equipment[]
  points    Point[]

  @@unique([siteId, name])
}

model Floor {
  id         String       @id @default(uuid())
  buildingId String
  name       String
  status     EntityStatus @default(ACTIVE)
  floorType       String?
  occupancyType   String?
  sortOrder       Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  building  Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  equipment Equipment[]
  points    Point[]

  @@unique([buildingId, name])
}

model Equipment {
  id            String       @id @default(uuid())
  siteId        String
  buildingId    String
  floorId       String
  name          String
  code          String
  equipmentType String
  /// Optional template label from Template Library (engineering)
  templateName  String?
  /// BACnet / controller-style address for mapping (user-entered in Site Builder)
  address       String?
  /// User-defined instance / tag (unique per site when set; Site Builder)
  instanceNumber String?
  status        EntityStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor    Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  points   Point[]
  alarmDefinitions AlarmDefinition[]
  alarmEvents      AlarmEvent[]

  @@unique([siteId, code])
  @@unique([siteId, instanceNumber])
}

enum AlarmSeverity {
  CRITICAL
  MAJOR
  MINOR
  WARNING
}

enum AlarmRuleCategory {
  BINARY
  THRESHOLD
  DEVIATION
  COMPARISON
}

enum AlarmOperator {
  EQ
  NEQ
  GT
  GTE
  LT
  LTE
  IS_ON
  IS_OFF
  DELTA_GT
  DELTA_GTE
  DELTA_LT
  DELTA_LTE
}

enum AlarmEventState {
  ACTIVE
  CLEARED
}

model Point {
  id           String       @id @default(uuid())
  equipmentId  String
  siteId       String
  buildingId   String
  floorId      String
  pointName    String
  pointCode    String
  pointType    String
  unit         String?
  writable     Boolean      @default(false)
  presentValue String?
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  building  Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor     Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)

  alarmDefinitionsAsSource AlarmDefinition[] @relation("AlarmDefinitionSourcePoint")
  alarmDefinitionsAsTarget AlarmDefinition[] @relation("AlarmDefinitionTargetPoint")
  alarmEvents              AlarmEvent[]      @relation("AlarmEventPoint")

  @@unique([equipmentId, pointCode])
}

model AlarmDefinition {
  id               String            @id @default(uuid())
  siteId           String
  buildingId       String?
  floorId          String?
  equipmentId      String
  /// Stable template / logical point key (e.g. zoneTemp); source of truth with equipmentId.
  pointKey         String
  /// Optional bound Point row when mapped in DB; may be null until discovery/mapping.
  pointId          String?
  name             String
  enabled          Boolean           @default(true)
  severity         AlarmSeverity     @default(WARNING)
  category         AlarmRuleCategory
  operator         AlarmOperator
  targetValue      Float?
  targetPointId    String?
  /// Logical reference on same equipment when target Point is not bound yet.
  targetPointKey   String?
  deadband         Float?
  delaySeconds     Int?
  messageTemplate  String?
  autoAcknowledge  Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  equipment    Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  point        Point?     @relation("AlarmDefinitionSourcePoint", fields: [pointId], references: [id], onDelete: SetNull)
  targetPoint  Point?     @relation("AlarmDefinitionTargetPoint", fields: [targetPointId], references: [id], onDelete: SetNull)
  events       AlarmEvent[]

  @@index([siteId])
  @@index([equipmentId])
  @@index([pointId])
  @@index([siteId, equipmentId, pointKey])
  @@index([siteId, enabled])
}

model AlarmEvent {
  id                String          @id @default(uuid())
  alarmDefinitionId String
  siteId            String
  equipmentId       String
  pointId           String
  state             AlarmEventState @default(ACTIVE)
  ack               Boolean         @default(false)
  occurredAt        DateTime        @default(now())
  clearedAt         DateTime?
  lastEvaluatedAt   DateTime?
  activeValue       String?
  clearValue        String?
  message           String
  durationSeconds   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  definition AlarmDefinition @relation(fields: [alarmDefinitionId], references: [id], onDelete: Cascade)
  site       Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  equipment  Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  point      Point           @relation("AlarmEventPoint", fields: [pointId], references: [id], onDelete: Cascade)

  @@index([siteId, state])
  @@index([alarmDefinitionId, state])
  @@index([equipmentId])
}

model User {
  id        String       @id @default(uuid())
  email     String       @unique
  name      String?
  status    EntityStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sitesCreated  Site[]           @relation("SitesCreatedByUser")
  userSiteAccess UserSiteAccess[]
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userSiteAccess UserSiteAccess[]
}

model UserSiteAccess {
  id        String   @id @default(uuid())
  userId    String
  siteId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, siteId])
}

/// Company-wide equipment template definitions (import creates a site-local copy in working version).
model GlobalEquipmentTemplate {
  id                 String       @id @default(uuid())
  name               String
  equipmentType      String
  description        String       @default("")
  defaultGraphicName String?
  pointsJson         Json         @default("[]")
  status             EntityStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  graphicTemplates GlobalGraphicTemplate[]

  @@index([equipmentType])
  @@index([status])
}

model GlobalGraphicTemplate {
  id                        String       @id @default(uuid())
  name                      String
  appliesToEquipmentType    String
  globalEquipmentTemplateId String?
  equipmentTemplateName     String?
  graphicEditorStateJson    Json?
  boundPointCount           Int          @default(0)
  status                    EntityStatus @default(ACTIVE)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  globalEquipmentTemplate GlobalEquipmentTemplate? @relation(fields: [globalEquipmentTemplateId], references: [id], onDelete: SetNull)

  @@index([appliesToEquipmentType])
  @@index([status])
}
